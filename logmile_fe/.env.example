# ============================================================
# logmile - unified environment template
# Copy this file to .env and fill values before running services.
# Do not commit real .env files.
#
# Docker Compose full-stack defaults are used here.
# For local Spring Boot runs from the IDE, use:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/logmile
# ============================================================

# PostgreSQL
POSTGRES_DB=logmile
POSTGRES_USER=logmile_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_PORT=5432

# Spring Boot BE
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/logmile
SPRING_DATASOURCE_USERNAME=logmile_user
SPRING_DATASOURCE_PASSWORD=your_password_here
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRATION_MS=86400000
BE_PORT=8080

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:80,http://localhost

# FastAPI AI
AI_HOST=0.0.0.0
AI_PORT=8000
OCR_CONFIDENCE_THRESHOLD=0.85
YOLO_MODEL_PATH=app/model/yolo11n.pt
DEBUG=false

# Vue.js FE
FE_PORT=80
VITE_API_BASE_URL=http://localhost:8080
VITE_AI_BASE_URL=http://localhost:8000

# GPS Simulator
BE_API_URL=http://backend:8080
GPS_ENDPOINT=/api/gps
PLATE_EVENT_ENDPOINT=/api/simulation/plate-events
AI_BASE_URL=http://ai:8000
OCR_ENDPOINT=/api/ocr/recognize
API_TOKEN=
DEFAULT_DRIVE_LOG_ID=1
DEFAULT_START_LATITUDE=37.5665
DEFAULT_START_LONGITUDE=126.9780
DEFAULT_INTERVAL_SECONDS=5
DEFAULT_SCENARIO=A
