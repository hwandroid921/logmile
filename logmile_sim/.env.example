# ── 백엔드 API URL ───────────────────────────────────────────
# 로컬 개발: http://localhost:8080
# Docker 환경: http://backend:8080
BACKEND_BASE_URL=http://localhost:8080
GPS_ENDPOINT=/api/gps
PLATE_EVENT_ENDPOINT=/api/simulation/plate-events

# ── AI FastAPI OCR URL ──────────────────────────────────────
# 로컬 개발: http://localhost:8000
# Docker 환경: http://ai:8000
AI_BASE_URL=http://localhost:8000
OCR_ENDPOINT=/api/ocr/recognize

# ── 인증 토큰 (JWT) ──────────────────────────────────────────
API_TOKEN=

# ── 시뮬레이션 기본 설정 ─────────────────────────────────────
DEFAULT_DRIVE_LOG_ID=1
DEFAULT_START_LATITUDE=37.5665
DEFAULT_START_LONGITUDE=126.9780
# GPS 전송 간격 (초)
DEFAULT_INTERVAL_SECONDS=5

# ── 시나리오 기본값 (A / B / C) ──────────────────────────────
DEFAULT_SCENARIO=A
