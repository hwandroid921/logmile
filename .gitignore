# ============================================================
# logmile 루트 .gitignore
# ============================================================

# ── 환경변수 (전 모듈 공통, 절대 커밋 금지) ─────────────────
.env
.env.local
.env.*.local

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 에디터 / IDE ─────────────────────────────────────────────
.vscode/

# IntelliJ IDEA / Android Studio
.idea/
*.iml
*.iws
*.ipr

# Eclipse / STS
.classpath
.project
.settings/
.springBeans
.sts4-cache
.apt_generated
.factorypath

# Vim
*.swp
*.swo

# ── Claude Code ──────────────────────────────────────────────
.claude/

# ── Frontend / Vue / Vite ───────────────────────────────────
node_modules/
dist/
.vite/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Java / Spring Boot / Gradle ─────────────────────────────
.gradle/
build/
out/
bin/
!gradle/wrapper/gradle-wrapper.jar

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ── AI / Runtime outputs ────────────────────────────────────
runs/
outputs/
uploads/
wandb/
mlruns/
*.onnx
*.engine

# ── AI 학습 결과물 / 모델 가중치 (로컬 또는 외부 저장소 보관) ─
logmile_ai/.venv/
logmile_ai/venv/
logmile_ai/env/
logmile_ai/runs/
logmile_ai/outputs/
logmile_ai/wandb/
logmile_ai/mlruns/
logmile_ai/.EasyOCR/
logmile_ai/uploads/
logmile_ai/tmp/
logmile_ai/**/*.pt
logmile_ai/**/*.pth
logmile_ai/**/*.onnx
logmile_ai/**/*.engine
logmile_ai/**/*.ckpt
logmile_ai/evaluate/results/*
!logmile_ai/evaluate/results/.gitkeep
logmile_ai/evaluate/ground_truth.json

# ── Local data ──────────────────────────────────────────────
*.db
*.sqlite
docker-data/
postgres-data/

# ── AI 데이터셋 원본 (대용량, 로컬 보관) ─────────────────────
logmile_ai/dataset/car_plate_data1/
logmile_ai/dataset/car_plate_data2/
logmile_ai/dataset/raw/
logmile_ai/dataset/images/train/
logmile_ai/dataset/images/val/
logmile_ai/dataset/images/test/
logmile_ai/dataset/labels/train/
logmile_ai/dataset/labels/val/
logmile_ai/dataset/labels/test/
