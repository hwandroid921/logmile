# ============================================================
# logmile 루트 .gitignore
# ============================================================

# ── 환경변수 (전 모듈 공통, 절대 커밋 금지) ─────────────────
.env
.env.local
.env.*.local

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 에디터 ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code ──────────────────────────────────────────────
.claude/

# ── Python / AI local runtime ────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ── AI 학습 결과물 / 모델 가중치 (로컬 또는 외부 저장소 보관) ─
runs/
outputs/
uploads/
wandb/
mlruns/
*.pt
*.pth
*.onnx
*.engine
*.ckpt
logmile_ai/.venv/
logmile_ai/venv/
logmile_ai/env/
logmile_ai/runs/
logmile_ai/outputs/
logmile_ai/wandb/
logmile_ai/mlruns/
logmile_ai/.EasyOCR/
logmile_ai/uploads/
logmile_ai/tmp/
logmile_ai/**/*.pt
logmile_ai/**/*.pth
logmile_ai/**/*.onnx
logmile_ai/**/*.engine
logmile_ai/**/*.ckpt
logmile_ai/evaluate/results/*
!logmile_ai/evaluate/results/.gitkeep
logmile_ai/evaluate/ground_truth.json

# ── AI 데이터셋 원본 / 라벨링 export (대용량, 로컬 보관) ─────
logmile_ai/dataset/car_plate_data1/
logmile_ai/dataset/car_plate_data2/
logmile_ai/dataset/raw/
logmile_ai/dataset/exports/
logmile_ai/dataset/roboflow/
logmile_ai/dataset/images/train/
logmile_ai/dataset/images/val/
logmile_ai/dataset/images/test/
logmile_ai/dataset/labels/train/
logmile_ai/dataset/labels/val/
logmile_ai/dataset/labels/test/
logmile_ai/dataset/*.zip
logmile_ai/dataset/*.tar
logmile_ai/dataset/*.tar.gz
logmile_ai/dataset/*.7z

# ── Simulation real plate image data (local only) ───────────
logmile_sim/plate/
