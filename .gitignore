# ============================================================
# logmile 루트 .gitignore
# ============================================================

# ── 환경변수 (전 모듈 공통, 절대 커밋 금지) ─────────────────
.env
.env.local
.env.*.local

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 에디터 ───────────────────────────────────────────────────
.vscode/
.idea
*.swp
*.swo

# ── Claude Code ──────────────────────────────────────────────
.claude/

# ── Frontend / Vue / Vite ───────────────────────────────────
node_modules/
dist/
.vite/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Java / Spring Boot / Gradle ─────────────────────────────
.gradle/
build/
out/
bin/
!gradle/wrapper/gradle-wrapper.jar

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ── AI / Runtime outputs ────────────────────────────────────
runs/
outputs/
uploads/
*.onnx
*.engine

# ── Local data ──────────────────────────────────────────────
*.db
*.sqlite
docker-data/
postgres-data/
